---
// src/layouts/Base.astro
export interface Props {
  title:        string;
  description:  string;
  canonicalURL?: string;
}
const { title, description, canonicalURL = Astro.url.href } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <link rel="canonical" href={canonicalURL}/>
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="alternate" type="application/rss+xml" title="American Foundations" href="/rss.xml"/>
</head>
<body>

  <nav class="site-nav" id="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="American Foundations home">
        <svg width="30" height="38" viewBox="0 0 96 122" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="4"  y="114" width="88" height="8"  fill="#C8A84B" rx="1"/>
          <rect x="10" y="108" width="76" height="7"  fill="#C8A84B" rx="1"/>
          <rect x="12" y="38"  width="18" height="70" fill="white" opacity="0.9"/>
          <rect x="37" y="22"  width="22" height="86" fill="#B22234"/>
          <rect x="66" y="38"  width="18" height="70" fill="white" opacity="0.9"/>
          <rect x="8"  y="32"  width="26" height="7"  fill="white" opacity="0.9" rx="1"/>
          <rect x="33" y="15"  width="30" height="8"  fill="#B22234" rx="1"/>
          <rect x="62" y="32"  width="26" height="7"  fill="white" opacity="0.9" rx="1"/>
          <rect x="4"  y="10"  width="88" height="6"  fill="#C8A84B" rx="1"/>
          <polygon points="24,6 25.5,1 27,6 22,3 29,3"        fill="#C8A84B"/>
          <polygon points="48,2 49.8,-4 51.6,2 44.5,-1 53,-1" fill="#C8A84B"/>
          <polygon points="72,6 73.5,1 75,6 70,3 77,3"        fill="#C8A84B"/>
        </svg>
        <div class="nav-logo-text">
          <span class="nav-logo-top">American Foundations</span>
          <span class="nav-logo-sub">Grounded in Principle. Clear in Purpose.</span>
        </div>
      </a>
      <ul class="nav-links" role="list">
        <li><a href="/#about">About</a></li>
        <li><a href="/articles">Articles</a></li>
        <li><a href="/#subscribe" class="nav-cta">Subscribe Free</a></li>
      </ul>
      <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
      <a href="/#about">About</a>
      <a href="/articles">Articles</a>
      <a href="/#subscribe">Subscribe Free</a>
    </div>
  </nav>

  <slot/>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-copy">© {new Date().getFullYear()} American Foundations · Written by Quenton Jordan · Published every weekday</p>
      <ul class="footer-links" role="list">
        <li><a href="/articles">Archive</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#subscribe">Subscribe</a></li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('site-nav');
    window.addEventListener('scroll', () => {
      if (nav) nav.style.background = window.scrollY > 60
        ? 'rgba(0,20,64,0.99)'
        : 'rgba(0,20,64,0.96)';
    }, { passive: true });

    const hamburger = document.getElementById('nav-hamburger');
    const mobileMenu = document.getElementById('nav-mobile');
    hamburger?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('open');
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach((el, i) => {
      (el as HTMLElement).style.transitionDelay = (i % 4) * 0.1 + 's';
      observer.observe(el);
    });
  </script>

</body>
</html>

<style is:global>
  /* ── CSS VARIABLES ─────────────────────────────────────── */
  :root {
    --navy:      #002868;
    --navy-deep: #001440;
    --navy-mid:  #001E54;
    --red:       #B22234;
    --red-dark:  #8C1A28;
    --gold:      #C8A84B;
    --gold-lt:   #E8C96A;
    --cream:     #FAF7F2;
    --cream-dk:  #F0EBE0;
    --ink:       #1A1A1A;
    --ink-mid:   #3D3D3D;
    --ink-soft:  #5A5A5A;
    --rule:      #DDD8CF;
    --white:     #FFFFFF;
  }

  /* ── RESET ─────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; font-size: 16px; }
  body {
    font-family: 'Source Serif 4', Georgia, serif;
    background: #FAF7F2;
    color: #1A1A1A;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  img { max-width: 100%; height: auto; display: block; }

  /* ── SHARED BUTTON STYLES ──────────────────────────────── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: #B22234;
    color: #FFFFFF !important;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    text-decoration: none !important;
    border: none;
    cursor: pointer;
    transition: background .2s, transform .15s;
  }
  .btn-primary:hover { background: #8C1A28; transform: translateY(-2px); }

  /* ── SCROLL REVEAL ─────────────────────────────────────── */
  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity .6s ease, transform .6s ease;
  }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── PILLAR COLORS ─────────────────────────────────────── */
  .pillar-principles { color: #002868; }
  .pillar-economy    { color: #1A5C1A; }
  .pillar-world      { color: #8B3A00; }
  .pillar-culture    { color: #B22234; }
  .pillar-news       { color: #7A6020; }
  .pillar-govt       { color: #5A1A8B; }

  /* ── NAV ───────────────────────────────────────────────── */
  .site-nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(0,20,64,0.96);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid #C8A84B;
    transition: background .3s;
  }
  .nav-inner {
    max-width: 1140px; margin: 0 auto;
    padding: 0 2rem; height: 62px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo { display: flex; align-items: center; gap: 11px; text-decoration: none; }
  .nav-logo-text { display: flex; flex-direction: column; line-height: 1; }
  .nav-logo-top {
    font-family: 'Playfair Display', serif;
    font-size: 15px; font-weight: 900;
    color: #FFFFFF; letter-spacing: 1.5px;
  }
  .nav-logo-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px; font-weight: 600;
    letter-spacing: 3px; text-transform: uppercase;
    color: #C8A84B; margin-top: 3px;
  }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,.75);
    text-decoration: none; transition: color .2s;
  }
  .nav-links a:hover { color: #C8A84B; }
  .nav-cta {
    background: #B22234 !important;
    color: #FFFFFF !important;
    padding: 7px 16px;
    transition: background .2s !important;
  }
  .nav-cta:hover { background: #8C1A28 !important; }

  .nav-hamburger {
    display: none; flex-direction: column;
    gap: 5px; background: none; border: none;
    cursor: pointer; padding: 6px;
  }
  .nav-hamburger span {
    display: block; width: 24px; height: 2px;
    background: #FFFFFF; transition: transform .2s, opacity .2s;
  }
  .nav-mobile {
    display: none; flex-direction: column;
    background: #001440;
    border-top: 1px solid rgba(200,168,75,.2);
    padding: 12px 2rem 20px; gap: 4px;
  }
  .nav-mobile.open { display: flex; }
  .nav-mobile a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,.8);
    text-decoration: none; padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  /* ── FOOTER ────────────────────────────────────────────── */
  .site-footer {
    background: #001440;
    border-top: 1px solid rgba(200,168,75,.2);
    padding: 32px 2rem;
  }
  .footer-inner {
    max-width: 1140px; margin: 0 auto;
    display: flex; align-items: center;
    justify-content: space-between; flex-wrap: wrap; gap: 16px;
  }
  .footer-copy {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,.4);
  }
  .footer-links { display: flex; gap: 24px; list-style: none; }
  .footer-links a {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,.4); text-decoration: none; transition: color .2s;
  }
  .footer-links a:hover { color: #C8A84B; }

  /* ── RESPONSIVE ────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-hamburger { display: flex; }
    .footer-inner { flex-direction: column; text-align: center; }
  }
</style>