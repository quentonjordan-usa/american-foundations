---
// src/pages/articles/index.astro  — Full article archive
import Base from '../../layouts/Base.astro';

const allArticles = await Astro.glob('./*.md').catch(() => []);
const articles = allArticles
  .filter(a => new Date(a.frontmatter.date + 'T12:00:00') <= new Date())
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<Base title="All Articles | American Foundations" description="Browse every article published on American Foundations — conservative analysis, five days a week.">

  <div class="arch-header">
    <div class="arch-header-inner">
      <div class="arch-kicker">★ Blog Archive</div>
      <h1 class="arch-title">All Articles</h1>
      <p class="arch-sub">{articles.length} articles published · Updated every weekday</p>
    </div>
  </div>

  <div class="arch-body">
    <div class="arch-inner">

      <!-- Filter -->
      <div class="filter-tabs" role="tablist">
        {['all','principles','economy','world','culture','news','govt'].map(f => (
          <button class={`ftab ${f === 'all' ? 'active' : ''}`} data-filter={f} role="tab">
            {f === 'all' ? 'All' : f === 'govt' ? 'Gov\'t' : f.charAt(0).toUpperCase() + f.slice(1)}
          </button>
        ))}
      </div>

      <!-- Article list -->
      <div id="article-list">
        {articles.map(article => (
          <a class="list-item" data-pillar={article.frontmatter.pillar} href={article.url}>
            <div class={`list-bar list-bar--${article.frontmatter.pillar}`}></div>
            <div class="list-body">
              <span class={`list-pillar pillar-${article.frontmatter.pillar}`}>
                {article.frontmatter.pillarName ?? article.frontmatter.pillar}
              </span>
              <h2 class="list-title">{article.frontmatter.title}</h2>
              <p class="list-excerpt">{article.frontmatter.description}</p>
            </div>
            <div class="list-meta">
              <span class="list-date">
                {new Date(article.frontmatter.date + 'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
              </span>
              <span class="list-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

      {articles.length === 0 && (
        <p class="empty-msg">No articles published yet. Check back on March 9, 2026 for the launch!</p>
      )}

    </div>
  </div>

  <script>
    document.querySelectorAll('.ftab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.ftab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const filter = (tab as HTMLElement).dataset.filter ?? 'all';
        document.querySelectorAll('.list-item').forEach(item => {
          const el = item as HTMLElement;
          el.style.display = (filter === 'all' || el.dataset.pillar === filter) ? 'flex' : 'none';
        });
      });
    });
  </script>

</Base>

<style>
  .arch-header {
    background: var(--navy-deep);
    padding: 110px 2rem 56px;
    border-bottom: 4px solid var(--gold);
  }
  .arch-header-inner { max-width: 900px; margin: 0 auto; }
  .arch-kicker {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 4px; text-transform: uppercase;
    color: var(--gold); margin-bottom: 14px;
  }
  .arch-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(32px, 5vw, 54px);
    font-weight: 900; color: var(--white);
    margin-bottom: 10px;
  }
  .arch-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px; font-weight: 500;
    letter-spacing: 2px; text-transform: uppercase;
    color: rgba(255,255,255,.45);
  }

  .arch-body { padding: 60px 2rem 80px; }
  .arch-inner { max-width: 900px; margin: 0 auto; }

  .filter-tabs { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 36px; }
  .ftab {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    padding: 7px 15px;
    border: 1.5px solid var(--rule);
    background: var(--white);
    color: var(--ink-soft);
    cursor: pointer;
    transition: all .18s;
  }
  .ftab:hover, .ftab.active { background: var(--navy); color: var(--white); border-color: var(--navy); }

  .list-item {
    display: flex;
    align-items: stretch;
    background: var(--white);
    border: 1px solid var(--rule);
    text-decoration: none;
    margin-bottom: 12px;
    transition: transform .2s, box-shadow .2s;
    overflow: hidden;
  }
  .list-item:hover { transform: translateX(4px); box-shadow: 0 4px 20px rgba(0,40,104,.07); }

  .list-bar { width: 5px; flex-shrink: 0; }
  .list-bar--principles { background: var(--navy); }
  .list-bar--economy    { background: #1A5C1A; }
  .list-bar--world      { background: #8B3A00; }
  .list-bar--culture    { background: var(--red); }
  .list-bar--news       { background: var(--gold); }
  .list-bar--govt       { background: #5A1A8B; }

  .list-body { flex: 1; padding: 20px 22px; }
  .list-pillar {
    display: block;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    margin-bottom: 6px;
  }
  .list-title { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 700; color: var(--ink); line-height: 1.3; margin-bottom: 6px; }
  .list-excerpt { font-size: 13px; color: var(--ink-soft); line-height: 1.6; }

  .list-meta {
    display: flex; flex-direction: column;
    align-items: flex-end; justify-content: center;
    padding: 20px 22px; gap: 8px;
    flex-shrink: 0; min-width: 140px;
  }
  .list-date {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .list-arrow { font-size: 20px; color: var(--gold); }
  .empty-msg { font-style: italic; color: var(--ink-soft); text-align: center; padding: 40px 0; }

  @media (max-width: 640px) {
    .list-item { flex-wrap: wrap; }
    .list-meta { flex-direction: row; justify-content: space-between; width: 100%; padding: 12px 22px; border-top: 1px solid var(--rule); }
  }
</style>